<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8EAF6"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_circle_soft"
                android:backgroundTint="#FFFFFF"
                android:padding="12dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="#191970"
                android:elevation="2dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Operation Log"
                android:textColor="#191970"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@id/btnBack"
                android:layout_marginStart="16dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_pill_soft"
                android:backgroundTint="#FFFFFF"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:gravity="center_vertical"
                android:elevation="1dp">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_calendar"
                    app:tint="#5C6BC0"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mon, 15 Jul"
                    android:textColor="#191970"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_tab_container"
            android:orientation="horizontal"
            android:padding="4dp"
            android:layout_marginBottom="24dp">
            
            <LinearLayout
                android:id="@+id/tabTrap"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_tab_active"
                android:paddingVertical="12dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ivTabTrap"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_nav_log"
                    app:tint="#FFFFFF"/>
                <TextView
                    android:id="@+id/tvTabTrap"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TRAP"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    android:letterSpacing="0.1"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tabBattery"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingVertical="12dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:id="@+id/ivTabBattery"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_battery_outline"
                    app:tint="#7986CB"/>
                <TextView
                    android:id="@+id/tvTabBattery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BATERAI"
                    android:textColor="#7986CB"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    android:letterSpacing="0.1"/>
            </LinearLayout>
        </LinearLayout>

        <!-- TRAP CONTENT CONTAINER -->
        <LinearLayout
            android:id="@+id/layoutTrapContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

        <!-- STATUS CARDS ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <!-- NIGHT CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_moon"
                        app:tint="@color/white"
                        android:background="@drawable/bg_circle_soft"
                        android:padding="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MALAM"
                        android:textColor="#7986CB"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp"
                        android:letterSpacing="0.1"/>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">
                                    <View android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/dot_green" />
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Sehat"
                                        android:textColor="#5C6BC0"
                                        android:textSize="12sp"
                                        android:layout_marginStart="6dp"/>
                    </LinearLayout>
                    <!-- Green border indicator at bottom -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:background="#5C6BC0"
                        android:layout_marginTop="16dp"
                        android:layout_marginHorizontal="-20dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- DAY CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_sun"
                        app:tint="@color/white"
                        android:background="@drawable/bg_circle_soft"
                        android:padding="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SIANG"
                        android:textColor="#7986CB"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp"
                        android:letterSpacing="0.1"/>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">
                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/bg_circle_soft"
                            android:backgroundTint="#9FA8DA"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LOG OPERASIONAL"
                            android:textColor="#7986CB"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginStart="6dp"/>
                    </LinearLayout>
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:background="@android:color/transparent"
                        android:layout_marginTop="16dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- ACTIVITY LOG CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="32dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">
                
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/iconLog"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_moon"
                        app:tint="@color/white"
                        android:background="@drawable/bg_circle_soft"
                        android:padding="6dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Log Aktivitas Malam"
                        android:textColor="#191970"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_centerVertical="true"
                        android:layout_toEndOf="@id/iconLog"
                        android:layout_marginStart="12dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7 Hari Terakhir"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_pill_soft"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>

                <TextView
                    android:id="@+id/tv_durasi_siklus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="11j 30m"
                    android:textColor="#191970"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginTop="24dp"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Durasi Siklus Terakhir"
                    android:textColor="#7986CB"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginBottom="24dp"/>

                <!-- Custom Timeline -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_pill_soft"
                        android:layout_centerVertical="true">
                        <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.5" />
                        <View 
                            android:layout_width="0dp" 
                            android:layout_height="match_parent" 
                            android:layout_weight="1" 
                            android:background="@drawable/bg_tab_active"/>
                    </LinearLayout>
                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00:00" android:textColor="#7986CB" android:textSize="12sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="18:00" android:textColor="#5C6BC0" android:textSize="14sp" android:textStyle="bold" android:layout_centerHorizontal="true"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="05:30" android:textColor="#191970" android:textSize="14sp" android:textStyle="bold" android:layout_alignParentEnd="true"/>
                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E8EAF6" android:layout_marginBottom="24dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3">
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mulai" android:textColor="#7986CB" android:textSize="12sp"/>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8dp">
                            <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_schedule" app:tint="#5C6BC0"/>
                            <TextView android:id="@+id/tv_mulai" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="18:00" android:textColor="#191970" android:textSize="16sp" android:textStyle="bold" android:layout_marginStart="4dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#E8EAF6"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Selesai" android:textColor="#7986CB" android:textSize="12sp"/>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8dp">
                            <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_schedule" app:tint="#191970"/>
                            <TextView android:id="@+id/tv_selesai" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="05:30" android:textColor="#191970" android:textSize="16sp" android:textStyle="bold" android:layout_marginStart="4dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#E8EAF6"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Durasi" android:textColor="#7986CB" android:textSize="12sp"/>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8dp">
                            <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_nav_log" app:tint="#191970"/>
                            <TextView android:id="@+id/tv_durasi" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="11.5j" android:textColor="#191970" android:textSize="16sp" android:textStyle="bold" android:layout_marginStart="4dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- RECENT CYCLES -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="32dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">
                
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SIKLUS TERBARU"
                        android:textColor="#7986CB"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="☰ 3 rekaman"
                        android:textColor="#7986CB"
                        android:textSize="12sp"
                        android:layout_alignParentEnd="true"/>
                </RelativeLayout>

                <!-- Item 1 -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="12dp">
                    <ImageView
                        android:id="@+id/iconItem1"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_moon"
                        app:tint="@color/white"
                        android:background="@drawable/bg_circle_soft"
                        android:padding="8dp"/>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_toEndOf="@id/iconItem1"
                        android:layout_marginStart="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Min, 14 Jul"
                            android:textColor="#191970"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="11j 30m"
                            android:textColor="#7986CB"
                            android:textSize="14sp"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OK"
                        android:textColor="#5C6BC0"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_badge_green"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="6dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E8EAF6" android:layout_marginVertical="4dp"/>

                <!-- Item 2 -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="12dp">
                    <ImageView
                        android:id="@+id/iconItem2"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_moon"
                        app:tint="@color/white"
                        android:background="@drawable/bg_circle_soft"
                        android:padding="8dp"/>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_toEndOf="@id/iconItem2"
                        android:layout_marginStart="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sab, 13 Jul"
                            android:textColor="#191970"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10j 45m"
                            android:textColor="#7986CB"
                            android:textSize="14sp"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OK"
                        android:textColor="#5C6BC0"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_badge_green"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="6dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E8EAF6" android:layout_marginVertical="4dp"/>

                <!-- Item 3 -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="12dp">
                    <ImageView
                        android:id="@+id/iconItem3"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_moon"
                        app:tint="@color/white"
                        android:background="@drawable/bg_circle_soft"
                        android:padding="8dp"/>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_toEndOf="@id/iconItem3"
                        android:layout_marginStart="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jum, 12 Jul"
                            android:textColor="#191970"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="11j 00m"
                            android:textColor="#7986CB"
                            android:textSize="14sp"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OK"
                        android:textColor="#5C6BC0"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_badge_green"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="6dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- BATTERY CONTENT CONTAINER -->
    <LinearLayout
            android:id="@+id/layoutBatteryContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- BATTERY STATUS CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center">
                    
                    <RelativeLayout
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:layout_marginTop="16dp">
                        <!-- Progress indicator (Circular) -->
                        <ProgressBar
                            android:id="@+id/pb_battery"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:indeterminate="false"
                            android:progress="85"
                            android:max="100"
                            android:progressDrawable="@drawable/circular_progress_bar"
                            style="?android:attr/progressBarStyleHorizontal" />
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_centerInParent="true"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/tv_battery_percent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="85%"
                                android:textColor="@color/white"
                                android:textSize="40sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Terisi"
                                android:textColor="#7986CB"
                                android:textSize="12sp"/>
                        </LinearLayout>
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="24dp"
                        android:background="@drawable/bg_pill_soft"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_charging"
                            app:tint="@color/white"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mengisi dari Tenaga Surya"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E8EAF6" android:layout_marginVertical="24dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="3">
                        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tegangan" android:textColor="#7986CB" android:textSize="10sp"/>
                            <TextView android:id="@+id/tv_voltage" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="12.6V" android:textColor="#191970" android:textSize="14sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Suhu" android:textColor="#7986CB" android:textSize="10sp"/>
                            <TextView android:id="@+id/tv_temp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="28°C" android:textColor="#191970" android:textSize="14sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kesehatan" android:textColor="#7986CB" android:textSize="10sp"/>
                            <TextView android:id="@+id/tv_health" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Baik" android:textColor="#5C6BC0" android:textSize="14sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SOLAR PANEL CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">
                    
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <ImageView
                            android:id="@+id/iconSolar"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_solar_panel"
                            app:tint="#FF9800"
                            android:background="@drawable/bg_circle_soft"
                            android:backgroundTint="#FFF3E0"
                            android:padding="6dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Efisiensi Tenaga Surya"
                            android:textColor="#191970"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_centerVertical="true"
                            android:layout_toEndOf="@id/iconSolar"
                            android:layout_marginStart="12dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Optimal"
                            android:textColor="#5C6BC0"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_badge_green"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"/>
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="24dp"
                        android:gravity="center_vertical">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Output Saat Ini"
                                android:textColor="#7986CB"
                                android:textSize="12sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="15.8W"
                                android:textColor="#191970"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <View android:layout_width="1dp" android:layout_height="40dp" android:background="#E8EAF6" android:layout_marginHorizontal="16dp"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Panen Hari Ini"
                                android:textColor="#7986CB"
                                android:textSize="12sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="142 Wh"
                                android:textColor="#191970"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <ProgressBar
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:progress="75"
                        android:progressDrawable="@drawable/bg_progress_fill_blue"
                        android:layout_marginTop="24dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="75% Efficiency based on weather"
                        android:textColor="#7986CB"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ESTIMATED TIME CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="24dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_schedule"
                        app:tint="#5C6BC0"
                        android:background="@drawable/bg_circle_soft"
                        android:padding="10dp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Estimated Time to Full"
                            android:textColor="#7986CB"
                            android:textSize="14sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1h 45m"
                            android:textColor="#191970"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
