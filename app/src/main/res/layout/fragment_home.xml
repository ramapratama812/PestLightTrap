<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#9AA7C2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER (ikon notifikasi + profil) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end|center_vertical"
            android:padding="24dp">

            <ImageView
                android:id="@+id/btn_bell"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_notifications"
                app:tint="@color/text_dark" />

            <ImageView
                android:id="@+id/btn_profile"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:padding="4dp"
                android:src="@drawable/ic_user"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                app:tint="@color/text_dark" />
        </LinearLayout>

        <!-- SECTION SMART LIGHT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SMART LIGHT"
                android:fontFamily="sans-serif-black"
                android:textSize="20sp"
                android:textColor="@color/black"
                android:layout_marginBottom="16dp"/>

            <!-- CONTAINER GAMBAR LAMPU (Perbaikan Posisi & Ukuran) -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false">

                <ImageView
                    android:id="@+id/img_lampu"
                    android:layout_width="220dp"
                    android:layout_height="280dp"
                    android:layout_gravity="end"
                    android:layout_marginEnd="0dp"
                    android:layout_marginTop="-40dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/lamp" />
            </FrameLayout>

            <!-- Toggle Power -->
            <LinearLayout
                android:id="@+id/toggle_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:background="@drawable/bg_toggle_on"
                android:padding="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">
                <TextView
                    android:id="@+id/txt_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ON"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp"/>
                <ImageView
                    android:id="@+id/btn_power"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_power"
                    app:tint="@color/white"
                    android:background="@drawable/bg_power_circle"
                    android:padding="4dp"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <!-- Card Operation Mode -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg_rounded"
                android:padding="20dp"
                android:orientation="vertical"
                android:elevation="4dp"
                android:layout_marginBottom="16dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OPERATION MODE"
                        android:fontFamily="sans-serif-black"
                        android:textSize="14sp"
                        android:textColor="@color/black"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="● SCHEDULED"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:layout_alignParentEnd="true"/>
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_icon_dark"
                        android:padding="12dp"
                        android:layout_marginEnd="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="START TIME" android:textSize="8sp" android:textColor="@color/white"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="06:00 PM" android:textColor="@color/white" android:textStyle="bold"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_icon_dark"
                        android:padding="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="END TIME" android:textSize="8sp" android:textColor="@color/white"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="06:00 AM" android:textColor="@color/white" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Card Current Power Draw -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg_rounded"
                android:padding="20dp"
                android:orientation="vertical"
                android:elevation="4dp"
                android:layout_marginBottom="24dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CURRENT POWER DRAW"
                        android:fontFamily="sans-serif-black"
                        android:textSize="12sp"
                        android:textColor="@color/black"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Efficiency: 98%"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:layout_alignParentEnd="true"/>
                </RelativeLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12.4 W"
                    android:fontFamily="sans-serif-black"
                    android:textSize="28sp"
                    android:textColor="@color/black"/>
            </LinearLayout>
        </LinearLayout>

        <!-- SECTION MONITORING PERANGKAT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="100dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MONITORING PERANGKAT"
                android:fontFamily="sans-serif-black"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"
                android:textColor="@color/text_dark"/>

            <!-- Status Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg_rounded"
                android:padding="24dp"
                android:orientation="vertical"
                android:elevation="6dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SENIN, 24 MARET 2026\n18:30 AM"
                    android:textSize="12sp"
                    android:textColor="@color/text_grey"
                    android:lineSpacingExtra="4dp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="24dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Status Perangkat" android:textSize="11sp" android:textColor="@color/text_grey"/>
                        <TextView android:id="@+id/status_aktif_dot" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="● AKTIF" android:textSize="14sp" android:fontFamily="sans-serif-black" android:textColor="@color/status_green" android:layout_marginTop="6dp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lampu" android:textSize="11sp" android:textColor="@color/text_grey"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MENYALA" android:textSize="14sp" android:fontFamily="sans-serif-black" android:textColor="@color/text_dark" android:layout_marginTop="6dp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Baterai" android:textSize="11sp" android:textColor="@color/text_grey"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="100%" android:textSize="14sp" android:fontFamily="sans-serif-black" android:textColor="@color/text_dark" android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Panel Surya Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg_rounded"
                android:padding="24dp"
                android:orientation="vertical"
                android:elevation="4dp"
                android:layout_marginBottom="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PENGISIAN PANEL SURYA" android:fontFamily="sans-serif-black" android:textSize="12sp" android:textColor="@color/text_dark"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚡ Baterai Penuh" android:fontFamily="sans-serif-black" android:textSize="12sp" android:textColor="@color/status_green" android:layout_alignParentEnd="true"/>
                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Status Panel Surya" android:fontFamily="sans-serif-black" android:textSize="20sp" android:textColor="@color/text_dark" android:drawableStart="@android:drawable/ic_menu_sort_by_size" android:drawablePadding="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="100%" android:fontFamily="sans-serif-black" android:textSize="24sp" android:textColor="@color/text_dark" android:layout_alignParentEnd="true"/>
                </RelativeLayout>

                <ProgressBar
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="16dp"
                    android:progress="100"
                    android:progressDrawable="@drawable/custom_progressbar" />
            </LinearLayout>

            <!-- Kondisi Perangkap Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="160dp"
                    android:background="@drawable/card_bg_rounded"
                    android:padding="20dp"
                    android:elevation="4dp"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="KONDISI\nPERANGKAP" android:fontFamily="sans-serif-black" android:textSize="11sp" android:textColor="@color/text_dark"/>
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_bug" app:tint="@color/text_dark" android:layout_alignParentEnd="true"/>
                    </RelativeLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="50%" android:fontFamily="sans-serif-black" android:textSize="40sp" android:textColor="@color/text_dark" android:layout_marginTop="16dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="↗ +12%" android:fontFamily="sans-serif-black" android:textColor="@color/status_green"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="160dp"
                    android:background="@drawable/card_bg_rounded"
                    android:padding="20dp"
                    android:elevation="4dp"
                    android:layout_marginStart="8dp"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AKTIVITAS\nPENGGUNAAN" android:fontFamily="sans-serif-black" android:textSize="11sp" android:textColor="@color/text_dark"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5j 24m" android:fontFamily="sans-serif-black" android:textSize="36sp" android:textColor="@color/text_dark" android:layout_marginTop="16dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>