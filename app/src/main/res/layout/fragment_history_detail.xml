<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8EAF6"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_circle_soft"
                android:backgroundTint="#FFFFFF"
                android:padding="12dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="#191970"
                android:elevation="2dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DETAIL RIWAYAT"
                android:textColor="#191970"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@id/btnBack"
                android:layout_marginStart="16dp"/>

            <LinearLayout
                android:id="@+id/btnCalendar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_pill_soft"
                android:backgroundTint="#FFFFFF"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:gravity="center_vertical"
                android:elevation="1dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_calendar"
                    app:tint="#5C6BC0"/>
                <TextView
                    android:id="@+id/tvHistoryDateBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="20 MEI"
                    android:textColor="#191970"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>
        </RelativeLayout>

        <!-- PHOTOGRAPHIC CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardPreventCornerOverlap="false">
            
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/img_trap_history"
                    android:scaleType="centerCrop"/>
                
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#4D000000"/>
                
                <TextView
                    android:id="@+id/tvHistoryImageDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="20dp"
                    android:text="• KAMIS, 20 MEI"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_gravity="top|start"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="20dp"
                    android:text="KONDISI PERANGKAP"
                    android:textColor="#E8EAF6"
                    android:textSize="12sp"
                    android:layout_gravity="bottom|start"/>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- OVERVIEW CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RINGKASAN SIKLUS"
                    android:textColor="#7986CB"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="16dp"/>

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:rowCount="2"
                    android:useDefaultMargins="true"
                    android:alignmentMode="alignBounds">

                    <!-- Stat 1 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_columnWeight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DURASI AKTIF"
                            android:textColor="#7986CB"
                            android:textSize="11sp"/>
                        <TextView
                            android:id="@+id/tvDetailDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="11J 30M"
                            android:textColor="#191970"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <!-- Stat 2 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_columnWeight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="STATUS ALAT"
                            android:textColor="#7986CB"
                            android:textSize="11sp"/>
                        <TextView
                            android:id="@+id/tvDetailStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AKTIF"
                            android:textColor="#4CAF50"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <!-- Stat 3 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_columnWeight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="KONSUMSI DAYA"
                            android:textColor="#7986CB"
                            android:textSize="11sp"/>
                        <TextView
                            android:id="@+id/tvDetailPower"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="80%"
                            android:textColor="#191970"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <!-- Stat 4 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_columnWeight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TEGANGAN"
                            android:textColor="#7986CB"
                            android:textSize="11sp"/>
                        <TextView
                            android:id="@+id/tvDetailVoltage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12.6V"
                            android:textColor="#191970"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </GridLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- PEST REPORT CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">
                    
                    <ImageView
                        android:id="@+id/iconBug"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_nav_log"
                        app:tint="#191970"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KONDISI PERANGKAP"
                        android:textColor="#191970"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_toEndOf="@id/iconBug"
                        android:layout_marginStart="10dp"
                        android:layout_centerVertical="true"/>

                    <TextView
                        android:id="@+id/tvDetailTotalPests"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="42 EKOR"
                        android:textColor="#5C6BC0"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_pill_soft"
                        android:backgroundTint="#E8EAF6"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:visibility="gone"/>
                </RelativeLayout>

                <!-- SMALL CARDS ROW INSIDE MAIN CARD -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="0dp"
                    android:weightSum="2">
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:background="@drawable/bg_box_rounded"
                        android:backgroundTint="#F5F6FF"
                        android:padding="16dp"
                        android:layout_marginEnd="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="STATUS KAPASITAS"
                            android:textColor="#7986CB"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="100%"
                            android:textColor="#191970"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">
                            <View android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/dot_green" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PENUH"
                                android:textColor="#191970"
                                android:textSize="12sp"
                                android:layout_marginStart="6dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:background="@drawable/bg_box_rounded"
                        android:backgroundTint="#F5F6FF"
                        android:padding="16dp"
                        android:layout_marginStart="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="JARAK PERMUKAAN"
                            android:textColor="#7986CB"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="50 / 20 cm"
                            android:textColor="#191970"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">
                            <View android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/dot_green" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="KOSONG"
                                android:textColor="#191970"
                                android:textSize="12sp"
                                android:layout_marginStart="6dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- STATUS DETAIL CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <View
                    android:layout_width="8dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_pill_soft"
                    android:backgroundTint="#4CAF50"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="KONDISI PERANGKAP AMAN DAN BERJALAN OPTIMAL SELAMA SIKLUS BERLANGSUNG."
                    android:textColor="#4CAF50"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginStart="16dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
