<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#E8EAF6">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_profile_placeholder"
                    android:background="@drawable/bg_circle_soft"
                    android:padding="8dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SELAMAT DATANG,"
                        android:textColor="#7986CB"
                        android:textSize="14sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BUDI SANTOSO"
                        android:textColor="#191970"
                        android:textSize="20sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/btnNotifications"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_notifications"
                        app:tint="@color/purple_navy"/>
                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/dot_red"
                        android:layout_gravity="top|end"/>
                </FrameLayout>
            </LinearLayout>

        <!-- CLOCK CARD (NEW) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    
                    <!-- Day/Night Icon -->
                    <FrameLayout
                        android:id="@+id/layoutDayNight"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentTop="true"
                        android:background="@drawable/bg_circle_soft"
                        android:backgroundTint="#191970"
                        android:padding="8dp">
                        <ImageView
                            android:id="@+id/ivDayNight"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_moon"
                            app:tint="#FFD54F"/>
                    </FrameLayout>
                    
                    <!-- Date -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentTop="true"
                        android:layout_toStartOf="@id/layoutDayNight"
                        android:layout_marginEnd="16dp"
                        android:layout_marginTop="6dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_calendar"
                            app:tint="#7986CB"
                            android:layout_marginEnd="8dp"/>
                        <TextView
                            android:id="@+id/tvDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SENIN, 18 MEI 2026"
                            android:textColor="#7986CB"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </RelativeLayout>

                <!-- Time -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/tvTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="18:30"
                        android:textColor="#191970"
                        android:textSize="48sp"
                        android:textStyle="bold"
                        android:includeFontPadding="false"/>
                    <TextView
                        android:id="@+id/tvAmPm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PM"
                        android:textColor="#7986CB"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginStart="8dp"
                        android:includeFontPadding="false"/>
                </LinearLayout>
                
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- RIWAYAT PERANGKAP CARD -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTrapHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:text="RIWAYAT PERANGKAP"
                        android:textColor="#7986CB"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>
                    
                    <TextView
                        android:id="@+id/tvHistoryBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="HARI INI"
                        android:textColor="#7986CB"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>
                </RelativeLayout>

                <!-- History Image/Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardPreventCornerOverlap="false">
                    
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">
                        
                        <ImageView
                            android:id="@+id/ivEspCamCapture"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/img_trap_history"
                            android:scaleType="centerCrop"/>
                        
                        <!-- Loading indicator while fetching ESP32-CAM image -->
                        <ProgressBar
                            android:id="@+id/pbCamLoading"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_gravity="center"
                            android:visibility="gone"
                            android:indeterminateTint="#5C6BC0"/>
                        
                        <!-- Semi-transparent overlay to ensure text contrast -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#33000000"/>
                        
                        <!-- Date text inside image -->
                        <TextView
                            android:id="@+id/tvHistoryItemDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="16dp"
                            android:text="• KAMIS, 20 MEI"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                        
                        <!-- Refresh button -->
                        <ImageView
                            android:id="@+id/btnRefreshCam"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_gravity="bottom|end"
                            android:layout_margin="12dp"
                            android:src="@drawable/ic_refresh"
                            android:background="@drawable/bg_circle_soft"
                            android:padding="8dp"
                            app:tint="#FFFFFF"
                            android:clickable="true"
                            android:focusable="true"/>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Button "Selengkapnya →" -->
                <TextView
                    android:id="@+id/btnMoreHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_button_navy"
                    android:text="SELENGKAPNYA →"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingVertical="12dp"
                    android:clickable="true"
                    android:focusable="true"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

            <!-- ROW 1 CARDS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- DEVICE STATUS -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="STATUS PERANGKAT"
                                android:textColor="#7986CB"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.1"/>
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:background="@drawable/bg_circle_soft"
                                android:padding="4dp"
                                android:src="@drawable/ic_lightbulb_outline"
                                app:tint="@color/white"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="16dp">
                            <TextView
                                android:id="@+id/tvDeviceStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="AKTIF"
                                android:textColor="#11df11"
                                android:textSize="18sp"
                                android:textStyle="bold"/>
                            <View
                                android:id="@+id/statusIndicator"
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:background="@drawable/dot_green"
                                android:layout_marginStart="8dp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BERJALAN NORMAL"
                            android:textColor="#7986CB"
                            android:textSize="12sp"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- CURRENT POWER DRAW -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="DAYA SAAT INI"
                                android:textColor="#7986CB"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.1"/>
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:background="@drawable/bg_circle_soft"
                                android:padding="4dp"
                                android:src="@drawable/ic_flash_on"
                                app:tint="@color/white"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="16dp">
                            <TextView
                                android:id="@+id/tvPowerValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="80"
                                android:textColor="#191970"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:includeFontPadding="false"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" %"
                                android:textColor="#7986CB"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:includeFontPadding="false"/>
                        </LinearLayout>
 
                        <TextView
                            android:id="@+id/tvPowerStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="KONSUMSI DAYA RENDAH"
                            android:textColor="#7986CB"
                            android:textSize="12sp"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- DEVICE CONTROL -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center_horizontal">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="KONTROL LAMPU"
                            android:textColor="#7986CB"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>
                        <TextView
                            android:id="@+id/tvToggleBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NYALA"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_pill_soft"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"/>
                    </LinearLayout>

                    <!-- Large Toggle Button -->
                    <FrameLayout
                        android:id="@+id/btnToggleDevice"
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        android:layout_marginTop="32dp"
                        android:background="@drawable/bg_circle_soft">
                        <View
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_power_button" />
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_power_white"
                            app:tint="@color/white" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KETUK UNTUK MENGHIDUPKAN/MEMATIKAN LAMPU"
                        android:textColor="#7986CB"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- OPERATION MODE -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="MODE OPERASI"
                            android:textColor="#7986CB"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>
                        <TextView
                            android:id="@+id/btnEditOperation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✎ UBAH"
                            android:textColor="#5C6BC0"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_pill_soft"
                        android:padding="16dp"
                        android:gravity="center_vertical"
                        android:layout_marginTop="16dp">
                        
                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_circle_soft"
                            android:backgroundTint="#FFFFFF"
                            android:padding="8dp"
                            android:src="@drawable/ic_schedule"
                            app:tint="#191970"/>
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="JADWAL AKTIF"
                                android:textColor="#FFFFFF"
                                android:textSize="12sp"/>
                            <TextView
                                android:id="@+id/tvOperationTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="18:00 — 06:00"
                                android:textColor="#FFFFFF"
                                android:textSize="16sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Days of Week -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:weightSum="7">
                        
                        <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content">
                            <TextView android:id="@+id/daySenin" android:layout_width="40dp" android:layout_height="40dp" android:text="S" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:background="@drawable/bg_power_button" android:clickable="true" android:focusable="true"/>
                        </FrameLayout>
                        <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content">
                            <TextView android:id="@+id/daySelasa" android:layout_width="40dp" android:layout_height="40dp" android:text="S" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:background="@drawable/bg_power_button" android:clickable="true" android:focusable="true"/>
                        </FrameLayout>
                        <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content">
                            <TextView android:id="@+id/dayRabu" android:layout_width="40dp" android:layout_height="40dp" android:text="R" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:background="@drawable/bg_power_button" android:clickable="true" android:focusable="true"/>
                        </FrameLayout>
                        <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content">
                            <TextView android:id="@+id/dayKamis" android:layout_width="40dp" android:layout_height="40dp" android:text="K" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:background="@drawable/bg_power_button" android:clickable="true" android:focusable="true"/>
                        </FrameLayout>
                        <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content">
                            <TextView android:id="@+id/dayJumat" android:layout_width="40dp" android:layout_height="40dp" android:text="J" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:background="@drawable/bg_power_button" android:clickable="true" android:focusable="true"/>
                        </FrameLayout>
                        <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content">
                            <TextView android:id="@+id/daySabtu" android:layout_width="40dp" android:layout_height="40dp" android:text="S" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:background="@drawable/bg_circle_soft" android:clickable="true" android:focusable="true"/>
                        </FrameLayout>
                        <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content">
                            <TextView android:id="@+id/dayMinggu" android:layout_width="40dp" android:layout_height="40dp" android:text="M" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:background="@drawable/bg_circle_soft" android:clickable="true" android:focusable="true"/>
                        </FrameLayout>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>



        <!-- SOLAR PANEL CHARGING (NEW) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/iconSolarNew"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_sun"
                        app:tint="#FF9800"
                        android:background="@drawable/bg_circle_soft"
                        android:backgroundTint="#191970"
                        android:padding="8dp"/>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_toEndOf="@id/iconSolarNew"
                        android:layout_marginStart="16dp"
                        android:layout_centerVertical="true">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MENGISI DAYA PANEL SURYA"
                            android:textColor="#191970"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tvSolarStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DAYA PENUH"
                            android:textColor="#4CAF50"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvSolarPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="100%"
                        android:textColor="#191970"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"/>
                </RelativeLayout>

                <ProgressBar
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="16dp"
                    android:progress="100"
                    android:progressDrawable="@drawable/bg_pill_soft" />
                
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0%" android:textColor="#7986CB" android:textSize="10sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="100%" android:textColor="#7986CB" android:textSize="10sp" android:layout_alignParentEnd="true"/>
                </RelativeLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ROW WITH 2 CARDS (NEW) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <!-- TRAP CONDITION -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">
                    
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_nav_log"
                        app:tint="@color/white"
                        android:background="@drawable/bg_circle_soft"
                        android:padding="6dp"/>
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KONDISI PERANGKAP"
                        android:textColor="#7986CB"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp"
                        android:letterSpacing="0.1"/>
                        
                    <!-- Circular Indicator -->
                    <RelativeLayout
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_marginTop="12dp">
                        <ProgressBar
                            android:id="@+id/pbTrapCircular"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:indeterminate="false"
                            android:progress="0"
                            android:max="100"
                            android:progressDrawable="@drawable/circular_progress_bar"
                            style="?android:attr/progressBarStyleHorizontal" />
                        <TextView
                            android:id="@+id/tvTrapPercent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="50%"
                            android:textColor="#191970"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_centerInParent="true"/>
                    </RelativeLayout>
                    
                    <TextView
                        android:id="@+id/tvTrapStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AMAN"
                        android:textColor="#FFA000"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- USAGE ACTIVITY -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">
                    
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_schedule"
                        app:tint="@color/white"
                        android:background="@drawable/bg_circle_soft"
                        android:padding="6dp"/>
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AKTIVITAS PERANGKAP"
                        android:textColor="#7986CB"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp"
                        android:letterSpacing="0.1"/>
                        
                    <TextView
                        android:id="@+id/tvActivityTimeRemaining"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5h 24m"
                        android:textColor="#191970"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp"/>
                        
                    <TextView
                        android:id="@+id/tvActivityPeriodLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MALAM INI"
                        android:textColor="#7986CB"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"/>
                        
                    <!-- Timeline progress bar -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="16dp">
                        
                        <!-- Background track -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_pill_soft"
                            android:backgroundTint="#E8EAF6"/>
                        
                        <!-- Progress fill -->
                        <View
                            android:id="@+id/viewActivityProgressFill"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_pill_soft"/>
                    </FrameLayout>
                        
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp">
                        <TextView android:id="@+id/tvActivityStartTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="18:00" android:textColor="#7986CB" android:textSize="10sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SEKARANG" android:textColor="#7986CB" android:textSize="10sp" android:layout_centerHorizontal="true"/>
                        <TextView android:id="@+id/tvActivityEndTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="06:00" android:textColor="#7986CB" android:textSize="10sp" android:layout_alignParentEnd="true"/>
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
