<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#E8EAF6">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_profile_placeholder"
                    android:background="@drawable/bg_circle_soft"
                    android:padding="8dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Good Evening,"
                        android:textColor="#7986CB"
                        android:textSize="14sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Budi Santoso"
                        android:textColor="#191970"
                        android:textSize="20sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/btnNotifications"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_notifications"
                        app:tint="#191970"/>
                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/dot_red"
                        android:layout_gravity="top|end"/>
                </FrameLayout>
            </LinearLayout>

            <!-- ROW 1 CARDS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- DEVICE STATUS -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="DEVICE STATUS"
                                android:textColor="#7986CB"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.1"/>
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:background="@drawable/bg_circle_soft"
                                android:padding="4dp"
                                android:src="@drawable/ic_lightbulb_outline"
                                app:tint="#7986CB"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="16dp">
                            <View
                                android:id="@+id/statusIndicator"
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:background="@drawable/dot_green"/>
                            <TextView
                                android:id="@+id/tvDeviceStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ACTIVE"
                                android:textColor="#4CAF50"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:layout_marginStart="8dp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Running normally"
                            android:textColor="#7986CB"
                            android:textSize="12sp"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- CURRENT POWER DRAW -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:text="CURRENT POWER DRAW"
                                android:textColor="#7986CB"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.1"/>
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:background="@drawable/bg_circle_soft"
                                android:padding="4dp"
                                android:src="@drawable/ic_flash_on"
                                app:tint="#7986CB"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="bottom"
                            android:layout_marginTop="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="12.4"
                                android:textColor="#191970"
                                android:textSize="28sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" W"
                                android:textColor="#7986CB"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="4dp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Low consumption"
                            android:textColor="#7986CB"
                            android:textSize="12sp"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- DEVICE CONTROL -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center_horizontal">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="DEVICE CONTROL"
                            android:textColor="#7986CB"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>
                        <TextView
                            android:id="@+id/tvToggleBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ON"
                            android:textColor="#4CAF50"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_badge_green"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"/>
                    </LinearLayout>

                    <!-- Large Toggle Button -->
                    <FrameLayout
                        android:id="@+id/btnToggleDevice"
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        android:layout_marginTop="32dp"
                        android:background="@drawable/bg_circle_soft">
                        <View
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_power_button" />
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_power_white" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TAP TO TOGGLE"
                        android:textColor="#7986CB"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- OPERATION MODE -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="OPERATION MODE"
                            android:textColor="#7986CB"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✎ Edit"
                            android:textColor="#5C6BC0"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_pill_soft"
                        android:padding="16dp"
                        android:gravity="center_vertical"
                        android:layout_marginTop="16dp">
                        
                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_circle_soft"
                            android:backgroundTint="#FFFFFF"
                            android:padding="8dp"
                            android:src="@drawable/ic_schedule"
                            app:tint="#191970"/>
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Active Schedule"
                                android:textColor="#7986CB"
                                android:textSize="12sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="06:00 PM — 06:00 AM"
                                android:textColor="#191970"
                                android:textSize="16sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Days of Week -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:weightSum="7">
                        
                        <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content">
                            <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="M" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:background="@drawable/bg_power_button"/>
                        </FrameLayout>
                        <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content">
                            <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="T" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:background="@drawable/bg_power_button"/>
                        </FrameLayout>
                        <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content">
                            <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="W" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:background="@drawable/bg_power_button"/>
                        </FrameLayout>
                        <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content">
                            <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="T" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:background="@drawable/bg_power_button"/>
                        </FrameLayout>
                        <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content">
                            <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="F" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:background="@drawable/bg_power_button"/>
                        </FrameLayout>
                        <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content">
                            <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="S" android:textColor="#7986CB" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:background="@drawable/bg_circle_soft"/>
                        </FrameLayout>
                        <FrameLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content">
                            <TextView android:layout_width="40dp" android:layout_height="40dp" android:text="S" android:textColor="#7986CB" android:textSize="14sp" android:textStyle="bold" android:gravity="center" android:layout_gravity="center" android:background="@drawable/bg_circle_soft"/>
                        </FrameLayout>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- TONIGHT'S CATCH -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="TONIGHT'S CATCH"
                        android:textColor="#7986CB"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        android:weightSum="3">
                        
                        <!-- Col 1 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:background="@drawable/bg_circle_soft"
                                android:padding="14dp"
                                android:src="@drawable/ic_bug_report" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="142"
                                android:textColor="#191970"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:layout_marginTop="8dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Insects"
                                android:textColor="#7986CB"
                                android:textSize="12sp"/>
                        </LinearLayout>
                        
                        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#D0D4E4" android:layout_marginVertical="12dp"/>

                        <!-- Col 2 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:background="@drawable/bg_circle_soft"
                                android:padding="14dp"
                                android:src="@drawable/ic_schedule" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="8h"
                                android:textColor="#191970"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:layout_marginTop="8dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Runtime"
                                android:textColor="#7986CB"
                                android:textSize="12sp"/>
                        </LinearLayout>
                        
                        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#D0D4E4" android:layout_marginVertical="12dp"/>

                        <!-- Col 3 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:background="@drawable/bg_badge_red"
                                android:backgroundTint="#FFF3E0"
                                android:padding="14dp"
                                android:src="@drawable/ic_local_fire_department" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.1"
                                android:textColor="#191970"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:layout_marginTop="8dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="kWh Used"
                                android:textColor="#7986CB"
                                android:textSize="12sp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

